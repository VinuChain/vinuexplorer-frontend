NEXT_PUBLIC_ROLLBAR_CLIENT_TOKEN=xxx
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=xxx
NEXT_PUBLIC_RE_CAPTCHA_APP_SITE_KEY=xxx
NEXT_PUBLIC_GOOGLE_ANALYTICS_PROPERTY_ID=UA-XXXXXX-X
NEXT_PUBLIC_MIXPANEL_PROJECT_TOKEN=xxx
NEXT_PUBLIC_GROWTH_BOOK_CLIENT_KEY=xxx

# ── Account / Tagging ──────────────────────────────────────────────────────────
# Enable the private tags, watchlist, API keys, and custom ABI features.
# Also requires NEXT_PUBLIC_RE_CAPTCHA_APP_SITE_KEY above.
NEXT_PUBLIC_IS_ACCOUNT_SUPPORTED=true

# Point both admin and metadata service at the vinuexplorer backend to enable
# the public tag submission form (/public-tags/submit) without a separate microservice.
# Replace <backend-host> with e.g. https://api.vinuexplorer.io
NEXT_PUBLIC_ADMIN_SERVICE_API_HOST=<backend-host>
NEXT_PUBLIC_METADATA_SERVICE_API_HOST=<backend-host>
